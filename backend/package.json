{
  "name": "sentinel-backend",
  "version": "1.0.0",
  "description": "Sentinel API - AI Pull Request Guardian",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "prisma": "prisma",
    "db:migrate": "prisma migrate dev --name",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "test": "node --test tests/**/*.test.js"
  },
  "keywords": [
    "ai",
    "code-review",
    "github",
    "pr",
    "sentinel"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "prisma": "^5.10.0"
  }
}
