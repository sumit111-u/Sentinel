// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int       @id @default(autoincrement())
  githubId            Int       @unique
  login               String
  name                String?
  email               String?
  avatarUrl           String?
  accessToken         String    // GitHub OAuth token
  createdAt           DateTime  @default(now())

  // Settings
  discordWebhookUrl   String?
  autoPostComments    Boolean   @default(true)
  checkSecurity       Boolean   @default(true)
  checkPerformance    Boolean   @default(true)
  checkCodeSmells     Boolean   @default(true)
  blockOnCritical     Int       @default(1)
  blockOnWarnings     Int       @default(10)

  // Relations
  reviews             Review[]

  @@index([githubId])
}

model Review {
  id                  Int       @id @default(autoincrement())
  userId              Int
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // PR Metadata
  repoFullName        String    // "owner/repo"
  prNumber            Int
  prTitle             String
  prAuthor            String
  prUrl               String
  baseBranch          String
  headBranch          String
  linesAdded          Int       @default(0)
  linesDeleted        Int       @default(0)

  // Review Results
  status              String    @default("pending") // pending | reviewed | error
  issuesCount         Int       @default(0)
  criticalCount       Int       @default(0)
  warningCount        Int       @default(0)
  infoCount           Int       @default(0)
  aiSummary           String?
  comments            String?   // JSON stringified array of comments
  detectedLanguages   String?   // JSON stringified array of languages

  createdAt           DateTime  @default(now())

  @@index([userId])
  @@index([repoFullName])
  @@unique([userId, repoFullName, prNumber])
}
